{
  "name": "aws-serverless-starter",
  "version": "1.0.0",
  "description": "A production-ready, open-source boilerplate for building scalable, robust, and cost-effective serverless APIs on AWS.",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "biome check .",
    "format": "biome format . --write",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "9.1.7",
    "serverless": "4.6.0",
    "typescript": "5.7.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1085.0",
    "@aws-sdk/client-eventbridge": "^3.1085.0",
    "@aws-sdk/lib-dynamodb": "^3.1085.0",
    "@middy/core": "6.0.0",
    "@middy/http-json-body-parser": "6.0.0",
    "@middy/http-response-serializer": "6.0.0",
    "zod": "^4.4.3"
  }
}
